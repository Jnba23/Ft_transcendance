{
  "env": {
    "node": true,
    "es2021": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:@typescript-eslint/recommended"
  ],
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "plugins": [
    "@typescript-eslint"
  ],
  "rules": {
    "no-unused-vars": "off",  // Turn off default rule
    "@typescript-eslint/no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    // Instead use TypeScript version, allow unused params starting with _
    "@typescript-eslint/explicit-function-return-types": "warn",
    // Warn if function doesn't have explicit return type
    "semi": ["error", "always"],
    // Error if missing semicolons
    "quotes": ["error", "single"],
    // Error if using double quotes instead of single
    "indent": ["error", 2],
    // Error if not using 2 spaces for indentation
    "no-console": "warn"
    // Warn about console.log in code
  }
}