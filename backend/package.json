{
  "name": "ft_transcendance-backend",
  "version": "1.0.0",
  "description": "Fastify backend for ft_transcendance",
  "main": "src/main.ts",
  "type": "module",
  "scripts": {
    "start": "node --loader ts-node/esm src/main.ts",
    "dev": "tsx watch src/main.ts",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts"
  },
  "dependencies": {
    "fastify": "^4.24.0",
    "@fastify/cors": "^8.4.0",
    "better-sqlite3": "^9.0.0",
    "dotenv": "^16.3.1",
    "ft_transcendance_shared": "github:Jnba23/ft_transcendance_shared#main"
  },
  "devDependencies": {
    "typescript": "^5.2.0",
    "tsx": "^4.0.0",
    "ts-node": "^10.9.0",
    "@types/node": "^20.4.0",
    "@types/better-sqlite3": "^7.6.5",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "@types/jest": "^29.5.3",
    "eslint": "^8.47.0",
    "@typescript-eslint/eslint-plugin": "^6.4.0",
    "@typescript-eslint/parser": "^6.4.0",
    "prettier": "^3.0.0"
  }
}